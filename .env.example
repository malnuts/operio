# Server-side only (upload scripts)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Browser-accessible public R2 asset URL (safe for client bundles)
# Example: https://pub-xxxxxxxxxxxxxxxx.r2.dev
VITE_R2_PUBLIC_BASE_URL=

# Optional key mapping:
# - Default behavior (VITE_R2_FLATTEN_KEYS not set): preserve full path.
#   /models/shared/tooth.glb -> <BASE>/models/shared/tooth.glb
# - Flat behavior (VITE_R2_FLATTEN_KEYS=true): use only filename.
#   /models/shared/tooth.glb -> <BASE>/assets/tooth.glb (default prefix "assets")
VITE_R2_FLATTEN_KEYS=
VITE_R2_KEY_PREFIX=
