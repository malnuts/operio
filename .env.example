# Server-side only (upload scripts)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Browser-accessible public R2 asset URL (optional)
# If set, this is used directly instead of signed URLs.
VITE_R2_PUBLIC_BASE_URL=

# Browser-accessible R2 credentials for signed URL generation
# Note: your R2 bucket must allow CORS for your site origin, otherwise
# browser model/video requests will fail even with valid signed URLs.
VITE_R2_ACCOUNT_ID=
VITE_R2_BUCKET_NAME=
VITE_R2_ACCESS_KEY_ID=
VITE_R2_SECRET_ACCESS_KEY=

# Optional key mapping:
# - Default behavior: flatten to filename and prefix with "assets"
#   /models/shared/tooth.glb -> assets/tooth.glb
# - Set VITE_R2_FLATTEN_KEYS=false to preserve full path
#   /models/shared/tooth.glb -> models/shared/tooth.glb
VITE_R2_FLATTEN_KEYS=
VITE_R2_KEY_PREFIX=
