# Server-side only (upload scripts)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Browser-accessible public R2 asset URL (optional)
# If set, the app derives remote asset URLs from the same local-style paths used in
# procedure JSON and visual references, for example:
#   /videos/procedures/demo.mp4 -> https://<public-base>/videos/procedures/demo.mp4
# If not set, the app defaults to the repo's configured R2 public development URL.
# Keep this public. Do not expose bucket credentials in Vite/browser env vars.
VITE_R2_PUBLIC_BASE_URL=

# Set to true only when you explicitly want local public/ assets instead of Cloudflare.
VITE_USE_LOCAL_ASSETS=

# Optional key mapping:
# - Default behavior: flatten to filename and prefix with "assets"
#   /models/shared/tooth.glb -> assets/tooth.glb
# - Set VITE_R2_FLATTEN_KEYS=false to preserve full path
#   /models/shared/tooth.glb -> models/shared/tooth.glb
VITE_R2_FLATTEN_KEYS=
VITE_R2_KEY_PREFIX=
